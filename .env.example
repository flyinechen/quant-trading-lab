# 量化交易实验室 - 环境变量配置
# Quantitative Trading Lab - Environment Variables

# ==================== 数据源 API ====================

# Tushare (股票数据)
# https://tushare.pro/
TUSHARE_TOKEN=your_tushare_token_here

# AKShare (免费数据源)
# https://akshare.xyz/
AKSHARE_ENABLED=true

# Binance (加密货币)
# https://www.binance.com/
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET=true

# Wind (金融数据终端)
WIND_USER=your_wind_user
WIND_PASSWORD=your_wind_password

# ==================== 数据库配置 ====================

# InfluxDB (时序数据)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your_influxdb_token
INFLUXDB_ORG=quant_lab
INFLUXDB_BUCKET=market_data

# PostgreSQL (关系型数据)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=quant_lab
POSTGRES_USER=quant_user
POSTGRES_PASSWORD=your_postgres_password

# ==================== 券商接口 ====================

# CTP (期货)
CTP_BROKER_ID=your_broker_id
CTP_USER_ID=your_user_id
CTP_PASSWORD=your_password
CTP_MD_ADDR=ctp_md_address
CTP_TD_ADDR=ctp_td_address
CTP_TEST_MODE=true

# ==================== 消息队列 ====================

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=quant_lab

# ==================== 系统配置 ====================

# 日志
LOG_LEVEL=INFO
LOG_FILE=logs/quant_lab.log

# 交易模式
TRADING_MODE=paper  # paper | real
PAPER_TRADING_INITIAL_CAPITAL=1000000

# 风控
MAX_POSITION_RATIO=0.3
MAX_DAILY_LOSS=50000
STOP_LOSS_PERCENT=0.05

# ==================== Web 界面 ====================

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# JWT
JWT_SECRET_KEY=your_jwt_secret_key_change_this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ==================== 监控 ====================

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_URL=http://localhost:3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_grafana_password
